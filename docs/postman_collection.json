      "item": [
        {
          "name": "Get Authenticated Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/users/me/profile",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "users",
                "me",
                "profile"
              ]
            }
          }
        },
